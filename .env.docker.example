# ─────────────────────────────────────────────────────────────────────────────
# .env.docker.example
# Copy to .env.docker and fill in the values before running docker-build.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (baked into the JS bundle at build time) ─────────────────────────
# When using --with-supabase these are set automatically to the local stack.
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_TWITCH_CLIENT_ID=deine_twitch_client_id

# ── Web server port ───────────────────────────────────────────────────────────
WEB_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# The following variables are only needed when running with --with-supabase
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase secrets ──────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
JWT_SECRET=super-secret-jwt-token-change-me

# Generate anon & service_role keys at https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# or use the supabase CLI: supabase gen keys
ANON_KEY=eyJ...
SERVICE_ROLE_KEY=eyJ...

# Generate with:  openssl rand -base64 64
SECRET_KEY_BASE=super-secret-key-base-change-me

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-db-password

# ── Twitch OAuth (for local Supabase Auth) ────────────────────────────────────
TWITCH_ENABLED=true
TWITCH_CLIENT_ID=deine_twitch_client_id
TWITCH_CLIENT_SECRET=dein_twitch_client_secret

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL of the Supabase API gateway (Kong)
API_EXTERNAL_URL=http://localhost:8000
# Public URL of the frontend (used for OAuth redirects)
SITE_URL=http://localhost:8080

# ── Kong ports ────────────────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ── Studio ────────────────────────────────────────────────────────────────────
STUDIO_PORT=3000
ORGANIZATION_NAME=Local
PROJECT_NAME=PTP4 Local

# ── Studio basic auth (dashboard login) ──────────────────────────────────────
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=supabase

# ── Logflare (optional, for Studio logs) ─────────────────────────────────────
LOGFLARE_API_KEY=
