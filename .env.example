# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for PTP4-landingpage-twitch-HD
# Copy this file to .env and fill in your own values.
# All VITE_* variables are embedded at build time by Vite and are public.
# ─────────────────────────────────────────────────────────────────────────────

# ── Twitch ──
# Your Twitch channel login name (lowercase), e.g. "mychannelname"
VITE_CHANNEL_NAME=hd1920x1080

# ── Supabase ──
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Twitch OAuth (same app as in Supabase → Auth → Providers → Twitch) ──
VITE_TWITCH_CLIENT_ID=deine_twitch_client_id

# ── Twitch Edge-Function Secrets (NOT exposed to the browser) ──
# Set these via: supabase secrets set TWITCH_CLIENT_ID=... TWITCH_CLIENT_SECRET=... TWITCH_CHANNEL=...
# TWITCH_CLIENT_ID     = same Client ID as above
# TWITCH_CLIENT_SECRET = Twitch App Client Secret (keep private!)
# TWITCH_CHANNEL       = Twitch channel login name (default: hd1920x1080)

# ── StreamElements ──
# Your StreamElements channel ID as shown in the donation URL:
# https://streamelements.com/<VITE_STREAMELEMENTS_CHANNEL>/tip
# Example: "mychannelname-1234"
VITE_STREAMELEMENTS_CHANNEL=hd1920x1080-5003

# ── Brand / Accent color ──
# Primary accent/contrast color used throughout the UI.
# Must be a 6-digit CSS hex value (e.g. "#7C4DFF" for purple, "#E91E63" for pink).
VITE_ACCENT_COLOR=#7C4DFF

# ── UI Languages ──
# Comma-separated list of BCP-47 language codes to enable in the language selector.
# Each code must have a matching file at src/i18n/locales/<code>.json.
# Defaults to all bundled locales (de, en, gsw) when not set.
VITE_LANGUAGES=de,en,gsw