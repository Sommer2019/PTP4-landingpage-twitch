SUPABASE_URL=https://<dein-projekt>.supabase.co
SUPABASE_API_KEY=<dein-supabase-service-key>
TWITCH_OAUTH_TOKEN=oauth:<dein-twitch-oauth-token>
TWITCH_CLIENT_ID=<deine-twitch-client-id>
TWITCH_CLIENT_SECRET=<dein-twitch-client-secret>
TWITCH_REFRESH_TOKEN=<dein-twitch-refresh-token>
CHANNEL_NAME=<dein-kanalname>

# Twitch Extension (für die Kanalpunkte-Extension im Twitch-Panel)
EXTENSION_CLIENT_ID=<extension-client-id-aus-dem-twitch-developer-dashboard>

# Twitch Extension Secret (Base64-kodiert, aus dem Twitch Developer Dashboard)
# Wird für die JWT-Verifikation benötigt, damit nur echte Extension-Nutzer Rewards einlösen können.
EXTENSION_SECRET=<base64-extension-secret-aus-dem-twitch-developer-dashboard>

# ngrok-Tunnel — gleichbleibende öffentliche HTTPS-Domain, die die EXE beim Start
# automatisch öffnet. Genau diese Domain muss in der Twitch-Extension unter
# "Allowlist for URLs Fetched by the Frontend" eingetragen sein.
# Eine kostenlose Static-Domain reservierst du im ngrok-Dashboard unter "Cloud Edge → Domains".
NGROK_AUTHTOKEN=<ngrok-authtoken>
NGROK_DOMAIN=<dein-static-domain>.ngrok-free.app
