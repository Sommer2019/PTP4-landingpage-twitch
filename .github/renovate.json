{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "platformAutomerge": false,
  "automerge": false,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchUpdateTypes": ["major", "patch", "pin", "digest", "rollback", "replacement"],
      "automerge": false
    }
  ]
}
